;
; BIND data file for local loopback interface
;
$ORIGIN krem.lan.
$TTL	604800
@	IN	SOA	dns.krem.lan. admin.krem.lan. (
			      2		; Serial
			 604800		; Refresh
			  86400		; Retry
			2419200		; Expire
			 604800 )	; Negative Cache TTL
;

@	IN	NS	dns.krem.lan.
dns       IN    A    10.10.0.10
oci       IN    A    10.10.0.10
gitlab    IN    A    10.10.0.10
gitlab    IN    A    10.10.0.10
prox      IN    A    10.10.0.3
