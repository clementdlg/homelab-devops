;                                    ;
;    ; Zone : krem.lan ;             ;
;                                    :
$ORIGIN krem.lan.
$TTL	604800
@	IN	SOA	dns.krem.lan. admin.krem.lan. (
			      6		; Serial
			 604800		; Refresh
			  86400		; Retry
			2419200		; Expire
			 604800 )	; Negative Cache TTL
;                                    ;
;    ; DNS Server ;                  ;
;                                    :
@	IN	NS	dns.krem.lan.
;                                    ;
;    ; Public Network ;              ;
;                                    :
prox           IN    A    10.10.0.1
docker01       IN    A    10.10.0.10
controller01   IN    A    10.20.0.101
compute01      IN    A    10.10.0.101
gateway        IN    A    10.10.0.254
;                                    ;
;    ; Docker ;                      ;
;                                    :
dns            IN    A    10.10.0.10
oci            IN    A    10.10.0.10
gitlab         IN    A    10.10.0.10
;                                    ;
;    ; Internal Network ;            ;
;                                    ;
prox           IN    A    10.20.0.1
controller01   IN    A    10.20.0.100
compute01      IN    A    10.20.0.101
